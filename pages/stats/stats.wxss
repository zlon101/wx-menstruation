.page {
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.summary-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
}

.summary-card {
  flex: 1;
  margin: 0;
  text-align: center;
  padding: 32rpx 16rpx;
}

.summary-value {
  display: block;
  font-size: 56rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.summary-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.tip-card {
  background: var(--color-primary-light);
}

.tip-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}
