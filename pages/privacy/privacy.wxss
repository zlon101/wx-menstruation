.page {
  min-height: 100vh;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.privacy-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.privacy-date {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 32rpx;
}

.privacy-section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.privacy-contract-link {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-primary);
}

.action-bar {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.decline-btn,
.accept-btn {
  flex: 1;
}
