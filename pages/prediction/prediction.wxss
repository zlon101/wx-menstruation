.page {
  min-height: 100vh;
  padding-bottom: 48rpx;
}

.section {
  margin-bottom: 0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.section-warn {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #D97706;
  line-height: 1.6;
}
