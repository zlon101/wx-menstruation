.privacy-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(0, 0, 0, 0.45);
}

.privacy-panel {
  width: 100%;
  max-width: 620rpx;
  padding: 40rpx 32rpx 32rpx;
  background: var(--color-card);
  border-radius: 24rpx;
}

.privacy-title {
  display: block;
  margin-bottom: 24rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
}

.privacy-text {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.privacy-link {
  display: block;
  margin-bottom: 32rpx;
  font-size: 26rpx;
  color: var(--color-primary);
}

.privacy-actions {
  display: flex;
  gap: 24rpx;
}

.decline-btn,
.agree-btn {
  flex: 1;
  margin: 0;
  padding: 20rpx 0;
  font-size: 30rpx;
}

.decline-btn::after,
.agree-btn::after {
  border: none;
}
