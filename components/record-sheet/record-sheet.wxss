.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.sheet-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.sheet-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 8rpx;
}

.sheet-date {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: 40rpx;
}

.action-list {
  margin-bottom: 24rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  height: 100rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 500;
}

.action-btn::after {
  border: none;
}

.start-btn {
  background: var(--color-primary);
  color: #FFFFFF;
}

.end-btn {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.action-icon {
  font-size: 36rpx;
}

.cancel-btn {
  background: transparent;
  color: var(--color-text-muted);
  font-size: 28rpx;
  border: none;
}

.cancel-btn::after {
  border: none;
}
