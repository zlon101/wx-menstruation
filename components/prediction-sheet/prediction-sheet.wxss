.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.sheet-panel {
  width: 100%;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.sheet-title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}

.content-scroll {
  flex: 1;
  max-height: 55vh;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

.close-btn {
  margin-top: 16rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  border: none;
}

.close-btn::after {
  border: none;
}
