.chart-wrap {
  position: relative;
  margin: 16rpx 0;
}

.chart-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  color: var(--color-text);
}

.chart-canvas {
  display: block;
  border-radius: 16rpx;
}

.chart-empty {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: var(--color-text-muted);
  font-size: 26rpx;
}
