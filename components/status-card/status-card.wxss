.status-card {
  margin: 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, var(--color-primary-light) 0%, #FFFFFF 100%);
  border-radius: 24rpx;
}

.status-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.3;
}

.info-btn {
  padding: 8rpx;
}

.info-icon {
  font-size: 32rpx;
}

.status-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
