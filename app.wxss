page {
  --color-primary: #E85D75;
  --color-primary-light: #FDE8EC;
  --color-primary-soft: #F9A8B4;
  --color-period: #E85D75;
  --color-period-predict: #F9C4CE;
  --color-ovulation: #7C6CF0;
  --color-fertile: #A78BFA;
  --color-bg: #F7F8FA;
  --color-card: #FFFFFF;
  --color-text: #1F2937;
  --color-text-secondary: #6B7280;
  --color-text-muted: #9CA3AF;
  --color-border: #E5E7EB;
  --color-danger: #EF4444;
  --safe-bottom: env(safe-area-inset-bottom);

  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

view,
text,
button,
input,
scroll-view {
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding-bottom: calc(120rpx + var(--safe-bottom));
}

.card {
  background: var(--color-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.text-secondary {
  color: var(--color-text-secondary);
}

.text-muted {
  color: var(--color-text-muted);
}

.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 48rpx;
  line-height: 1.4;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
}

.btn-outline::after {
  border: none;
}

.btn-danger {
  background: #FEF2F2;
  color: var(--color-danger);
  border: 2rpx solid #FECACA;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
}

.btn-danger::after {
  border: none;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-label {
  font-size: 30rpx;
  color: var(--color-text);
}

.list-item-arrow {
  color: var(--color-text-muted);
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  color: var(--color-text-muted);
  text-align: center;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
